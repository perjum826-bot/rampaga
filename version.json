    def restore_backup(self):
        if not self.game_path: return
        bd = os.path.join(self.game_path, "backup_original")
        try:
            for s, f in [("w", "assets/weapons"), ("s", "assets/skins"), ("effects", "effects")]:
                src = os.path.join(bd, s)
                if os.path.exists(src):
                    for fl in os.listdir(src): shutil.copy2(os.path.join(src, fl), os.path.join(self.game_path, "models", f, fl))
            ib = os.path.join(bd, "i", "weapons.txd")
            if os.path.exists(ib): shutil.copy2(ib, os.path.join(self.game_path, "models", "interface", "weapons.txd"))
        except: pass

