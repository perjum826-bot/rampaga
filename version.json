        else: self.remove_path_from_history(p)

    def add_new_path(self):
        p = QFileDialog.getExistingDirectory(self, "Папка игры")
        if p:
            p = os.path.normpath(p)
            if p not in self.game_paths_history: self.game_paths_history.insert(0, p)
            if len(self.game_paths_history) > 5: self.game_paths_history.pop()
            self.settings.setValue("game_paths_history", json.dumps(self.game_paths_history)); self.set_game_path(p)

    def remove_path_from_history(self, p):
        if p in self.game_paths_history: self.game_paths_history.remove(p);
            self.settings.setValue("game_paths_history", json.dumps(self.game_paths_history)); self.path_menu.close(); self.select_folder()

    def select_server(self, btn, name, color):
        for b in self.btns: b.setChecked(False);
            b.setStyleSheet("color: #666; background: transparent; font-weight: 900; font-size: 15px; border: none; outline: none;");
            b.setGraphicsEffect(None)
        btn.setChecked(True); btn.setStyleSheet(f"color: {color}; background: transparent; font-weight: 900; font-size: 17px;"); self.apply_glow(btn, color, 20);
        self.selected_srv = name; self.play_btn.setStyleSheet(f"background: {color}; color: black; font-weight: 900; border-radius: 12px;"); self.apply_glow(self.play_btn, color, 30);
        if self.pulse_anim.state() == QAbstractAnimation.Stopped: self.pulse_anim.start()
        
        n = self.server_nicks.get(name, [])
        if n: self.nick.setText(n[-1])
        else: self.nick.clear()

    def mousePressEvent(self, event):
        if event.button() == Qt.LeftButton: self._drag_pos = event.globalPos() - self.frameGeometry().topLeft();
            event.accept()
    def mouseMoveEvent(self, event):
        if event.buttons() == Qt.LeftButton and self._drag_pos: self.move(event.globalPos() - self._drag_pos);
            event.accept()

