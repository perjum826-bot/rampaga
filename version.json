class HoverButton(QPushButton):
    def __init__(self, text, normal_style, hover_style, parent=None):
        super().__init__(text, parent);
        self.normal_style, self.hover_style = normal_style, hover_style; self.setStyleSheet(self.normal_style)
    def enterEvent(self, event): self.setStyleSheet(self.hover_style);
        super().enterEvent(event)
    def leaveEvent(self, event): self.setStyleSheet(self.normal_style); super().leaveEvent(event)

class AsiToggleButton(QPushButton):
    def __init__(self, text, is_on, parent=None):
        super().__init__(text, parent)
        self.setCheckable(True)
        self.setChecked(is_on)
        self.setFixedSize(50, 28)
        self.setCursor(Qt.PointingHandCursor)
        self.is_on = is_on 
        
        self._thumb_x = 22 if is_on else 2 
       
        self._anim = QPropertyAnimation(self, b"thumb_pos", self)
        self._anim.setDuration(200)
        self._anim.setEasingCurve(QEasingCurve.OutQuad)

    @pyqtProperty(int)
    def thumb_pos(self):
        return self._thumb_x

    @thumb_pos.setter
    def thumb_pos(self, value):
        self._thumb_x = value
        self.update()

    def setChecked(self, checked):
        super().setChecked(checked)
        self.is_on = checked
        self._thumb_x = 22 if checked else 2
        self.update()
        
    def nextCheckState(self):
        super().nextCheckState()
        self.is_on = self.isChecked()
        start = self._thumb_x
        end = 22 if self.isChecked() else 2
        self._anim.setStartValue(start)
        self._anim.setEndValue(end)
        self._anim.start()

    def update_style(self):
        self.update()

    def paintEvent(self, e):
        p = QPainter(self)
        p.setRenderHint(QPainter.Antialiasing)
        
        bar_color = QColor("#32D74B") if self.isChecked() else QColor("#39393D")
        p.setBrush(bar_color)
        p.setPen(Qt.NoPen)
        p.drawRoundedRect(0, 0, 50, 28, 14, 14)
        
        p.setBrush(Qt.white)
        p.drawEllipse(self._thumb_x, 2, 24, 24)

class GameMonitor(QThread):
    game_finished = pyqtSignal()
    def __init__(self, game_proc, rs_proc):
        super().__init__();
        self.game_proc, self.rs_proc = game_proc, rs_proc
    def run(self):
        self.game_proc.wait()
        if self.rs_proc:
            try: os.kill(self.rs_proc.pid, signal.SIGTERM)
            except: pass
        self.game_finished.emit()

