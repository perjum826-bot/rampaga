    def load_tg_news(self):
        t = threading.Thread(target=self._fetch_telegram)
        t.daemon = True
        t.start()

    def _fetch_telegram(self):
        CHANNEL_URL = "https://t.me/s/lishaikaaaa" 
        try:
            try: import requests
            except ImportError: raise Exception("Модуль requests не установлен")

            session = requests.Session()
            headers = {
                'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/115.0.0.0 Safari/537.36',
                'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8',
                'Accept-Language': 'ru-RU,ru;q=0.9,en-US;q=0.8,en;q=0.7',
                'Cache-Control': 'max-age=0',
                'Connection': 'keep-alive',
                'Upgrade-Insecure-Requests': '1'
            }
            
            response = session.get(CHANNEL_URL, headers=headers, timeout=10)
            html = response.content.decode('utf-8')
            posts = re.findall(r'class="tgme_widget_message_text[^>]+>(.*?)</div>', html, re.DOTALL)
            
            final_html = "<h3 style='color: #ff5555; margin-top:0;'>📢 Новости проекта</h3>"
            if not posts: final_html += "<p>Не удалось загрузить новости. (Блокировка Telegram)</p>"
            
            for post in posts[:5]:
                text = post.replace("<br>", "<br>").replace("</i>", "</i>").replace("</b>", "</b>")
                text = re.sub(r'<a[^>]*class="[^"]*tgme_widget_message_photo_wrap[^"]*"[^>]*>.*?</a>', '', text)
                final_html += f"<div style='margin-bottom: 15px; border-bottom: 1px solid #444; padding-bottom: 10px; color: #ccc;'>{text}</div>"
            
            self.tg_html_content = final_html
        except Exception as e:
            self.tg_html_content = f"<h3 style='color: red;'>Ошибка загрузки новостей</h3><p>{str(e)}</p>"

        QtCore.QMetaObject.invokeMethod(self, "update_tg_display", QtCore.Qt.QueuedConnection)

    @QtCore.pyqtSlot()
    def update_tg_display(self):
        if hasattr(self, 'tg_html_content'):
            self.tg_block.setHtml(self.tg_html_content)

