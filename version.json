        title.setAlignment(Qt.AlignCenter)
        layout.addWidget(title)

        # Переключатель цветов (Табы)
        sel_frame = QFrame()
        sel_frame.setFixedHeight(40)
        sel_frame.setStyleSheet("background: #0A0A0B; border-radius: 12px; border: none;")
        sel_layout = QHBoxLayout(sel_frame)
        sel_layout.setContentsMargins(5,5,5,5)
        sel_layout.setSpacing(5)
        
        self.btn_c1 = QPushButton("Цвет 1")
        self.btn_c1.setCheckable(True)
        self.btn_c1.clicked.connect(lambda: self.set_active_color(1))
        
        self.btn_c2 = QPushButton("Цвет 2")
        self.btn_c2.setCheckable(True)
        self.btn_c2.clicked.connect(lambda: self.set_active_color(2))
        
        sel_layout.addWidget(self.btn_c1)
        sel_layout.addWidget(self.btn_c2)
        layout.addWidget(sel_frame)
        
        # Область цвета и слайдер
        h_layout = QHBoxLayout()
        self.area = ColorArea()
        self.area.colorChanged.connect(self.on_area_change)
        
        self.hue_slider = QSlider(Qt.Vertical)
        self.hue_slider.setRange(0, 359)
        self.hue_slider.setFixedWidth(20)
        self.hue_slider.setStyleSheet("""
            QSlider::groove:vertical { 
                background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #FF0000, stop:0.17 #FF00FF, stop:0.33 #0000FF, stop:0.5 #00FFFF, stop:0.67 #00FF00, stop:0.83 #FFFF00, stop:1 #FF0000);
                width: 10px; border-radius: 5px; 
            } 
            QSlider::handle:vertical { background: white; height: 14px; margin: 0 -5px; border-radius: 7px; border: 1px solid #777; }
        """)
        self.hue_slider.valueChanged.connect(self.on_hue_slider_change)
        
        h_layout.addWidget(self.area)
        h_layout.addWidget(self.hue_slider)
        layout.addLayout(h_layout)

        # Превью
        prev_lbl = QLabel("ПРЕДПРОСМОТР")
        prev_lbl.setStyleSheet("color: #777; font-size: 10px; font-weight: bold; border: none; margin-top: 5px;")
        layout.addWidget(prev_lbl)
        
        self.preview = QFrame()
        self.preview.setFixedHeight(50)
        layout.addWidget(self.preview)

        layout.addStretch()

        # Кнопки действий
        btn_layout = QHBoxLayout()
        apply_btn = QPushButton("ПРИМЕНИТЬ")
        apply_btn.setFixedHeight(45)
        apply_btn.setStyleSheet("""
            QPushButton { background: #32D74B; color: black; font-weight: 900; border-radius: 15px; border: none; }
            QPushButton:hover { background: #28c13f; }
        """)
        apply_btn.clicked.connect(lambda: (self.gradient_selected.emit(self.c1.name(), self.c2.name()), self.close()))
        
        close_btn = QPushButton("✕")
        close_btn.setFixedSize(45, 45)
        close_btn.setStyleSheet("""
            QPushButton { background: #2C2C2E; color: white; border-radius: 15px; border: none; }
            QPushButton:hover { background: #3A3A3C; color: #FF453A; }
        """)
        close_btn.clicked.connect(self.close)
        
        btn_layout.addWidget(apply_btn)
        btn_layout.addWidget(close_btn)
        layout.addLayout(btn_layout)

        self.set_active_color(1)
        self.update_preview()

    def set_active_color(self, idx):
        self.active_idx = idx
        self.btn_c1.setChecked(idx == 1)
        self.btn_c2.setChecked(idx == 2)
        
        # Стиль табов
        active_style = "background: #2C2C2E; color: white; border-radius: 8px; font-weight: bold; border: 1px solid #444;"
        inactive_style = "background: transparent; color: #666; border-radius: 8px; font-weight: bold; border: none;"
        
        self.btn_c1.setStyleSheet(active_style if idx == 1 else inactive_style)
        self.btn_c2.setStyleSheet(active_style if idx == 2 else inactive_style)

        # Синхронизация палитры
        curr = self.c1 if idx == 1 else self.c2
        self.hue_slider.blockSignals(True)
        self.hue_slider.setValue(359 - (curr.hue() if curr.hue() != -1 else 0))
        self.hue_slider.blockSignals(False)
        self.area.setColor(curr)

    def on_hue_slider_change(self, val):
        self.area.setHue(359 - val)
        self.area.handleMouse(type('obj', (object,), {'x': lambda: int(self.area.sat/255*self.area.width()), 'y': lambda: int((255-self.area.val)/255*self.area.height())}))

    def on_area_change(self, color):
        if self.active_idx == 1: self.c1 = color
        else: self.c2 = color
        self.update_preview()

    def update_preview(self):
        style = f"background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, stop:0 {self.c1.name()}, stop:1 {self.c2.name()}); border-radius: 15px; border: 1px solid #555;"
        self.preview.setStyleSheet(style)

