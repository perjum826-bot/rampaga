# --- ПОТОКИ ДЛЯ АВТООБНОВЛЕНИЯ ---
class UpdateWorker(QThread):
    update_available = pyqtSignal(str, str) # version, download_url
    
    def run(self):
        try:
            import requests
            response = requests.get(UPDATE_URL, timeout=5)
            data = response.json()
            # Проверяем, новее ли версия на сервере
            if float(data.get("version", "1.0")) > float(CURRENT_VERSION):
                self.update_available.emit(str(data["version"]), data.get("url", ""))
        except Exception as e:
            pass # Если нет интернета или ошибка - просто молчим

class DownloadUpdateWorker(QThread):
    progress = pyqtSignal(int)
    finished = pyqtSignal(bool, str)

    def __init__(self, url):
        super().__init__()
        self.url = url

    def run(self):
        try:
            import requests
            response = requests.get(self.url, stream=True)
            total_length = response.headers.get('content-length')
            
            # Определяем путь текущего exe
            exe_path = sys.executable
            if not exe_path.endswith('.exe'):
                exe_path = os.path.abspath(__file__)
                
            new_exe_path = exe_path + ".update"
            
            with open(new_exe_path, "wb") as f:
                if total_length is None:
                    f.write(response.content)
                else:
                    dl = 0
                    total_length = int(total_length)
                    for data in response.iter_content(chunk_size=4096):
                        dl += len(data)
                        f.write(data)
                        self.progress.emit(int(100 * dl / total_length))
            self.finished.emit(True, new_exe_path)
        except Exception as e:
            self.finished.emit(False, str(e))

