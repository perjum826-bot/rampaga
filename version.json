    def check_and_install_soft(self, soft_type, name):
        p = os.path.join(self.game_path, "quick_asi.exe") if soft_type == "QUICK" else os.path.join(self.game_path, "!ReShade")
        if os.path.exists(p):
            self.reinstall_dlg = ReinstallDialog(self, name) 
            self.reinstall_dlg.confirmed.connect(lambda: self.start_soft_install(soft_type, self.btn_i_r if soft_type == "RESHADE" else None))
            geo = self.geometry();
            x = (geo.width() - self.reinstall_dlg.width()) // 2; y = (geo.height() - self.reinstall_dlg.height()) // 2;
            self.reinstall_dlg.move(x, y)
            self.reinstall_dlg.show()
        else: self.start_soft_install(soft_type, self.btn_i_r if soft_type == "RESHADE" else None)

    def start_soft_install(self, soft_type, btn):
        if btn:
            btn.setEnabled(False);
            btn.setText("ЗАГРУЗКА..."); 
        self.sw = SoftInstallWorker(soft_type, self.game_path); 
        self.sw.finished.connect(lambda r, m: self.on_soft_finish(r, m, btn));
        self.sw.start()
        
    def on_soft_finish(self, success, msg, btn):
        if btn:
            btn.setEnabled(True);
            self.refresh_soft_ui()
        if not success and btn: btn.setText(f"ОШИБКА: {msg[:10]}");
            QTimer.singleShot(3000, self.refresh_soft_ui)

    def refresh_asi_list(self):
        if not self.asi_ui_created: return
        while self.asi_layout.count():
            item = self.asi_layout.takeAt(0)
            if item.widget(): item.widget().deleteLater()
        ad = os.path.join(self.game_path, "ASI");
        os.makedirs(ad, exist_ok=True)
        for f in os.listdir(ad):
            if f.lower().endswith((".asi", ".disabled")):
                en = f.lower().endswith(".asi");
                r = QFrame(); r.setMinimumHeight(55); r.setStyleSheet("background: #161618; border-radius: 4px; border: 1px solid #222;");
                rl = QHBoxLayout(r)
                n = QLabel(f.replace(".disabled", "").upper());
                n.setStyleSheet("color: #EEE; font-weight: bold; border: none; background: transparent;"); b = AsiToggleButton("ВКЛ" if en else "ВЫКЛ", en);
                b.clicked.connect(lambda ch, fl=f: self.toggle_asi_file(fl))
                rl.addWidget(n);
                rl.addStretch(); rl.addWidget(b); self.asi_layout.addWidget(r)
        self.asi_layout.addStretch()

    def toggle_asi_file(self, f):
        d = os.path.join(self.game_path, "ASI");
        old = os.path.join(d, f); new = old + ".disabled" if f.lower().endswith(".asi") else old.replace(".disabled", "")
        try: os.rename(old, new);
            QTimer.singleShot(100, self.refresh_asi_list)
        except: pass

    def start_game(self):
        try:
            if self.selected_srv and self.game_path:
                nick = self.nick.text().strip()
                if not nick: return
                if self.selected_srv not in self.server_nicks: self.server_nicks[self.selected_srv] = []
                if nick in self.server_nicks[self.selected_srv]: self.server_nicks[self.selected_srv].remove(nick)
                self.server_nicks[self.selected_srv].append(nick);
                self.settings.setValue("server_nicks_v2", json.dumps(self.server_nicks))
                self.last_srv_key = self.selected_srv;
                self.settings.setValue("last_selected_server", self.selected_srv)
                rsp = None
                if self.use_reshade:
                    l = os.path.join(self.game_path, "!ReShade", "ReShadeLoader.exe")
                    if os.path.exists(l): rsp = subprocess.Popen([l], cwd=os.path.dirname(l));
                        time.sleep(1)
                ip, port = SERVERS[self.selected_srv]["ip"].split(":");
                exe = os.path.join(self.game_path, "aggstarter.exe")
                if os.path.exists(exe):
                    gp = subprocess.Popen([exe, "-amazing", "-c", "-h", ip, "-p", port, "-n", nick, "-fastconnect", "--stream", "--launcher"], cwd=self.game_path)
                    q = os.path.join(self.game_path, "quick_asi.exe")
                    if os.path.exists(q): subprocess.Popen([q, "-p", "gta_sa.exe", "-silent"], cwd=self.game_path, creationflags=0x08000000)
                    
                    self.hide()
                    self.mt = GameMonitor(gp, rsp)
                    self.mt.game_finished.connect(self.on_game_finished)
                    self.mt.start()
        except: pass
    
    def on_game_finished(self):
        self.show()
        self.setWindowState(Qt.WindowNoState)
        self.activateWindow()

