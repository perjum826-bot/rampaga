        self.tray_icon.activated.connect(self.tray_activated)
        self.tray_icon.show()

    def tray_activated(self, reason):
        if reason == QSystemTrayIcon.DoubleClick:
            self.restore_from_tray()

    def restore_from_tray(self):
        self.showNormal()
        self.activateWindow()

    def hide_to_tray(self):
        self.hide()

    def check_for_updates(self):
        self.upd_worker = UpdateWorker()
        self.upd_worker.update_available.connect(self.on_update_available)
        self.upd_worker.start()

    def on_update_available(self, version, url):
        reply = QMessageBox.question(
            self, 'Доступно обновление!', 
            f'Вышла новая версия лаунчера: v{version}.\nХочешь обновиться сейчас?\n\n(Лаунчер перезапустится автоматически)', 
            QMessageBox.Yes | QMessageBox.No, QMessageBox.Yes
        )
        if reply == QMessageBox.Yes and url:
            self.start_downloading_update(url)

    def start_downloading_update(self, url):
        self.progress_dlg = QProgressDialog("Загрузка обновления...", "Отмена", 0, 100, self)
        self.progress_dlg.setWindowTitle("Обновление")
        self.progress_dlg.setWindowModality(Qt.WindowModal)
        self.progress_dlg.setMinimumDuration(0)
        self.progress_dlg.setValue(0)
        
        self.dl_worker = DownloadUpdateWorker(url)
        self.dl_worker.progress.connect(self.progress_dlg.setValue)
        self.dl_worker.finished.connect(self.on_download_finished)
        self.progress_dlg.canceled.connect(self.dl_worker.terminate)
        self.dl_worker.start()

    def on_download_finished(self, success, new_exe_path):
        if hasattr(self, 'progress_dlg'): self.progress_dlg.close()
        
        if success:
            current_exe = sys.executable
            if not current_exe.endswith('.exe'):
                QMessageBox.information(self, "Обновление", f"Ты запускаешь код через Python.\nОбновление скачано сюда:\n{new_exe_path}")
                return

            # Создаем bat-скрипт для подмены файла
            bat_path = os.path.join(os.path.dirname(current_exe), "updater.bat")
            bat_content = f"""@echo off
timeout /t 2 /nobreak > NUL
del "{current_exe}"
ren "{new_exe_path}" "{os.path.basename(current_exe)}"
start "" "{current_exe}"
del "%~f0"
"""
            with open(bat_path, "w", encoding="utf-8") as f:
                f.write(bat_content)
            
            # Запускаем батник без окна и закрываем лаунчер
            subprocess.Popen(bat_path, creationflags=subprocess.CREATE_NO_WINDOW)
            QApplication.quit()
        else:
            QMessageBox.critical(self, "Ошибка", f"Не удалось скачать обновление:\n{new_exe_path}")

    def setup_logging(self):
        if self.game_path and os.path.exists(self.game_path):
            log_file = os.path.join(self.game_path, "launcher_log.txt");
            fh = logging.FileHandler(log_file, encoding="utf-8"); fh.setFormatter(logging.Formatter("%(asctime)s - %(message)s"));
            root = logging.getLogger(); [root.removeHandler(h) for h in root.handlers[:]];
            root.addHandler(fh)

