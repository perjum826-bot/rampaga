class ColorArea(QWidget):
    colorChanged = pyqtSignal(QColor)
    def __init__(self, parent=None):
        super().__init__(parent)
        self.hue, self.sat, self.val = 0, 255, 255
        self.setFixedSize(220, 200)

    def setHue(self, h):
        self.hue = h
        self.update()
        
    def setColor(self, c):
        self.hue = c.hue()
        if self.hue == -1: self.hue = 0
        self.sat = c.saturation()
        self.val = c.value()
        self.update()

    def paintEvent(self, event):
        p = QPainter(self)
        p.setRenderHint(QPainter.Antialiasing)
       
        # Создаем закругленный путь для обрезки
        path = QPainterPath()
        path.addRoundedRect(0, 0, self.width(), self.height(), 15, 15)
        p.setClipPath(path)

        for x in range(self.width()):
            grad = QLinearGradient(0, 0, 0, self.height())
            s = x / self.width() * 255
            grad.setColorAt(0, QColor.fromHsv(self.hue, int(s), 255))
            grad.setColorAt(1, Qt.black)
            p.fillRect(x, 0, 1, self.height(), grad)
            
        pos_x = int(self.sat / 255 * self.width())
        pos_y = int((255 - self.val) / 255 * self.height())
        
        # Рисуем кружок курсора
        p.setPen(QPen(Qt.white if self.val < 128 else Qt.black, 2))
        p.setBrush(Qt.NoBrush)
        p.drawEllipse(QPoint(pos_x, pos_y), 8, 8)

    def mousePressEvent(self, event): self.handleMouse(event)
    def mouseMoveEvent(self, event): self.handleMouse(event)
    def handleMouse(self, event):
        x, y = max(0, min(event.x(), self.width())), max(0, min(event.y(), self.height()))
        self.sat = int(x / self.width() * 255)
        self.val = int(255 - (y / self.height() * 255))
        self.colorChanged.emit(QColor.fromHsv(self.hue, self.sat, self.val))
        self.update()

