class InstallWorker(QThread):
    finished = pyqtSignal(bool)
    def __init__(self, pack_path, game_path, mod_type):
        super().__init__();
        self.pack_path, self.game_path, self.mod_type = pack_path, game_path, mod_type
    def run(self):
        try:
            backup_dir = os.path.join(self.game_path, "backup_original")
            if self.mod_type == "WEAPONS":
                p_models, p_inter = os.path.join(self.game_path, "models", "assets", "weapons"), os.path.join(self.game_path, "models", "interface")
                for file in os.listdir(self.pack_path):
                    f_l, dest, sub = file.lower(), None, ""
                    if f_l.endswith((".txd", ".dff")) and f_l != "weapons.txd": dest = os.path.join(p_models, file);
                        sub = "w"
                    elif f_l == "weapons.txd": dest = os.path.join(p_inter, file);
                        sub = "i"
                    if dest:
                        if os.path.exists(dest):
                            b_file = os.path.join(backup_dir, sub, file)
                        if not os.path.exists(b_file): os.makedirs(os.path.dirname(b_file), exist_ok=True);
                            shutil.copy2(dest, b_file)
                        os.makedirs(os.path.dirname(dest), exist_ok=True);
                        shutil.copy2(os.path.join(self.pack_path, file), dest)
            elif self.mod_type == "SKINS":
                p_skins = os.path.join(self.game_path, "models", "assets", "skins")
                for file in os.listdir(self.pack_path):
                    if file.lower().endswith((".txd", ".dff")):
                        dest = os.path.join(p_skins, file)
                        if os.path.exists(dest):
                            b_file = os.path.join(backup_dir, "s", file)
                            if not os.path.exists(b_file): os.makedirs(os.path.dirname(b_file), exist_ok=True);
                                shutil.copy2(dest, b_file)
                        os.makedirs(p_skins, exist_ok=True);
                        shutil.copy2(os.path.join(self.pack_path, file), dest)
            elif self.mod_type == "EFFECTS":
                p_effects = os.path.join(self.game_path, "models", "effects")
                for file in os.listdir(self.pack_path):
                    if file.lower() in ["effectspc.txd", "effects.fxp"]:
                        dest = os.path.join(p_effects, file); b_file = os.path.join(backup_dir, "effects", file)
                        if os.path.exists(dest) and not os.path.exists(b_file): os.makedirs(os.path.dirname(b_file), exist_ok=True);
                            shutil.copy2(dest, b_file)
                        os.makedirs(p_effects, exist_ok=True);
                        shutil.copy2(os.path.join(self.pack_path, file), dest)
            self.finished.emit(True)
        except: self.finished.emit(False)

class SoftInstallWorker(QThread):
    finished = pyqtSignal(bool, str)
    def __init__(self, type_soft, game_path):
        super().__init__()
        self.type_soft = type_soft
        self.game_path = game_path
    
    def download_file_from_google_drive(self, file_id, destination):
        try:
            import requests
        except ImportError:
            raise Exception("Модуль requests не установлен")

        URL = "https://docs.google.com/uc?export=download&confirm=t"
        session = requests.Session()
        response = session.get(URL, params={'id': file_id}, stream=True)
        token = self.get_confirm_token(response)
        if token:
            params = {'id': file_id, 'confirm': token}
            response = session.get(URL, params=params, stream=True)
        content_type = response.headers.get('Content-Type', '')
        if 'text/html' in content_type: raise Exception("Ошибка загрузки Google Drive")
        self.save_response_content(response, destination)

    def get_confirm_token(self, response):
        for key, value in response.cookies.items():
            if key.startswith('download_warning'): return value
        return None

    def save_response_content(self, response, destination):
        CHUNK_SIZE = 32768
        with open(destination, "wb") as f:
            for chunk in response.iter_content(CHUNK_SIZE):
                if chunk: f.write(chunk)

    def run(self):
        import zipfile
        try:
            file_id = LINKS.get(self.type_soft)
            if not file_id:
               self.finished.emit(False, "ID не найден")
               return
            temp_dir = tempfile.gettempdir()
            temp_zip = os.path.join(temp_dir, f"lisha_dl_{self.type_soft}.zip")
            self.download_file_from_google_drive(file_id, temp_zip)
            try:
                with zipfile.ZipFile(temp_zip, 'r') as z:
                    if self.type_soft == "QUICK":
                        try: z.extractall(self.game_path, pwd=b"1234")
                        except (RuntimeError, zipfile.BadZipFile): z.extractall(self.game_path)
                    else: z.extractall(self.game_path)
            except Exception as e:
                 self.finished.emit(False, f"Ошибка архива: {e}")
                 if os.path.exists(temp_zip): os.remove(temp_zip)
                 return
            if os.path.exists(temp_zip): os.remove(temp_zip)
            self.finished.emit(True, "Успешно")
        except Exception as e:
            self.finished.emit(False, str(e))

